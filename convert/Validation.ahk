;################################################################################
V2ReservedMap() {
	resvMap := Map(), resvMap.CaseSense := 0
	for idx, word in StrSplit(gV2ReservedWords, '|') {
		if (!Trim(word))
			continue
		resvMap[word] := true
	}
	return resvMap
}
;################################################################################
isValidVarName(name) {																				; returns whether srcStr can be used as a valid v2 variable name
; 2026-03-29 AMB, ADDED: returns whether srcStr can be used as a valid v2 variable name
; 2026-04-06 AMB, UPDATED: moved from MaskCode.ahk
; 	validation currently fails for dynamic vars...
;	... such as %var%idx%, even tho this is a legit var
;	TODO - ADD SUPPORT FOR DYNAMIC VARS
	return clsVarValidation.Validate(Trim(name))
}
;################################################################################
isValidGuiName(name) {																				; returns whether srcStr can be used as a valid v2 gui name
; 2026-04-06 AMB, ADDED: returns whether srcStr can be used as a valid v2 gui name
	return clsVarValidation.Validate(Trim(name))
}
;################################################################################
; 2026-04-06 AMB, MOVED: consolidated from MaskCode.ahk and Converter_UI.ahk
class clsVarValidation
{
	Static Validate(name,emptyOK:=false,resvOK:=false) {											; main validation
		; name must be trimmed of whitespace, to be valid
		if (emptyOK && name='')																		; if empty string is allowed, and name is empty...
			return true																				; ... return VALID
		if (!this.IsValidVarSyntax(name))															; if name syntax is invalid
			return false																			; ... return INVALID
		return !(!resvOK && this.IsV2Reserved(name))												; if resv not ok, and name is resv word, return false, otherwise true
	}
	;############################################################################
	Static IsValidVarIntp(name) {		; 2026-03-17 magic... THANK YOU @ntepa !					; determines whether name is ahk reserved
	; 2026-04-04 - uses AHK interpreter to determine whether name is valid var
	; 	works but VERY SLOW!
		; name must be trimmed of whitespace, to be valid
		if (name ~= '[[:^ascii:]]')																	; if name has any chars that are NOT ascii...
			return false																			; ... is not a AHK reserved word
		shell := ComObject('WScript.Shell')
		exec := shell.Exec('AutoHotkey.exe /ErrorStdOut *')											; will execute a var assignment (dynamically) and report errors
		exec.StdIn.Write(Format('FileAppend({} := 1, "*")', name))									; create dynamic var assignment, write to std in
		exec.StdIn.Close()																			; close std in stream
		return !exec.StdOut.ReadAll()																; return whether error occurred during var creation
	}
	;############################################################################
	Static IsV2Reserved(name) {						; 2026-04-04 AMB, ADDED							; determines whether name is ahk reserved
		; name must be trimmed of whitespace, to be valid
		if (name ~= '[[:^ascii:]]')																	; if name has any chars that are NOT ascii...
			return false																			; ... is not a AHK reserved word
		return !!(InStr(gV2ReservedWords, '|' name '|')) ; tested with no delay						; return whether name is in reserved word list
	}
	;############################################################################
	Static IsValidVarSyntax(name) {																	; must not begin with number, allows ascii/unicode chars
		; name must be trimmed of whitespace, to be valid
		return	(name ~= '(?i)^([_a-z]|([[:^ascii:]]))(\w|(?2))*$')
	}
}